prefix=/Users/lileggplant/OpenBB/conda/envs/openbb
exec_prefix=${prefix}
libdir=/Users/lileggplant/OpenBB/conda/envs/openbb/lib
includedir=/Users/lileggplant/OpenBB/conda/envs/openbb/include

Name: absl_flags_commandlineflag_internal
Description: Abseil flags_commandlineflag_internal library
URL: https://abseil.io/
Version: 20260107
Requires: absl_config = 20260107, absl_dynamic_annotations = 20260107, absl_fast_type_id = 20260107
Libs: -L${libdir}  -labsl_flags_commandlineflag_internal 
Cflags: -I${includedir} -Wno-float-conversion -Wno-implicit-float-conversion -Wno-implicit-int-float-conversion -Wno-unknown-warning-option -Wno-unused-command-line-argument -DNOMINMAX
